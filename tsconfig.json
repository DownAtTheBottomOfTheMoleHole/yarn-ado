{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "ignoreDeprecations": "5.0",
        "noImplicitAny": true,
        "removeComments": true,
        "preserveConstEnums": true,
        "target": "ES2024",
        "lib": ["ES2024"],
        "sourceMap": false,
        "inlineSourceMap": true,
        "declaration": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    }
   
}
