{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "types": ["node", "jasmine"],
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "target": "ESNext",
    "lib": ["ESNext"],
    "sourceMap": false,
    "inlineSourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
