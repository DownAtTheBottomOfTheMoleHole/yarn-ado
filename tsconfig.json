{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "ignoreDeprecations": "6.0",
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "types": ["node", "jasmine"],
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "target": "ES2024",
    "lib": ["ES2024"],
    "sourceMap": false,
    "inlineSourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
