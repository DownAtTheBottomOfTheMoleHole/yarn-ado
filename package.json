{
  "name": "gl-vsts-tasks-yarn",
  "version": "0.1.0",
  "description": "Yarn task for the Team Services build system",
  "engines": {
    "node": ">=24.0.0"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "clean": "node ./node_modules/gl-vsts-tasks-build-scripts/run/vsts-build-tools-clean",
    "prepare": "husky",
    "postinstall": "node ./node_modules/gl-vsts-tasks-build-scripts/run/vsts-build-tools-install",
    "prebuild": "node ./node_modules/gl-vsts-tasks-build-scripts/run/vsts-build-tools-prebuild",
    "build": "tsc",
    "package": "node ./node_modules/gl-vsts-tasks-build-scripts/run/vsts-build-tools-package",
    "test": "run-s build test:no-build",
    "test:no-build": "node test.js",
    "fix:prettier": "prettier Tasks/**/*.ts --write",
    "lint": "eslint --no-warn-ignored Tasks/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/geeklearningio/gl-vsts-tasks-yarn"
  },
  "keywords": [
    "yarn",
    "node",
    "node.js",
    "npm",
    "npm.js",
    "install"
  ],
  "author": "Geek Learning, Adrien Siffermann, Cyprien Autexier",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/geeklearningio/gl-vsts-tasks-yarn/issues"
  },
  "homepage": "https://github.com/geeklearningio/gl-vsts-tasks-yarn/vsts-tasks",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/ini": "^4.1.1",
    "@types/ltx": "^3.1.1",
    "@types/node": "^25.5.0",
    "@types/q": "^1.5.8",
    "@types/jasmine": "^6.0.0",
    "@types/tar": "^7.0.87",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "async": "^3.2.6",
    "eslint": "^10.1.0",
    "gl-vsts-tasks-build-scripts": "^0.6.0",
    "husky": "^9.1.7",
    "karma": "^6.4.4",
    "npm-run-all": "4.1.5",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "typescript": "^5.9.3",
    "jasmine-reporters": "^2.5.2",
    "jasmine": "^6.1.0"
  },
  "dependencies": {}
}
