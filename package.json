{
  "name": "yarn-ado",
  "version": "1.0.0",
  "description": "Azure DevOps extension for Yarn Classic and modern Yarn 2+ workflows in pipelines",
  "engines": {
    "node": ">=24.0.0"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "clean": "node ./BuildScripts/clean.js",
    "prepare": "husky",
    "postinstall": "node ./BuildScripts/sync-task-node-modules.js",
    "prebuild": "node ./BuildScripts/prebuild.js",
    "build": "tsc",
    "package": "node ./BuildScripts/generate-configuration-json.js && node ./BuildScripts/package-extension.js",
    "test": "run-s build test:no-build",
    "test:no-build": "node test.js",
    "fix:prettier": "prettier Tasks/**/*.ts --write",
    "lint": "eslint --no-warn-ignored Tasks/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado"
  },
  "keywords": [
    "yarn",
    "node",
    "node.js",
    "npm",
    "npm.js",
    "install",
    "azure-devops",
    "azure-pipelines"
  ],
  "author": "DownAtTheBottomOfTheMoleHole",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado/issues"
  },
  "homepage": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado#readme",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/ini": "^4.1.1",
    "@types/ltx": "^3.1.1",
    "@types/node": "^25.5.0",
    "@types/q": "^1.5.8",
    "@types/jasmine": "^6.0.0",
    "@types/tar": "^7.0.87",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "async": "^3.2.6",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "karma": "^6.4.4",
    "npm-run-all": "4.1.5",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "typescript": "^5.9.3",
    "jasmine-reporters": "^2.5.2",
    "jasmine": "^6.1.0",
    "tfx-cli": "^0.23.1"
  },
  "dependencies": {
    "azure-devops-node-api": "^15.1.2",
    "azure-pipelines-task-lib": "^5.2.8",
    "azure-pipelines-tool-lib": "^2.0.12",
    "fs-extra": "^11.3.4",
    "https-proxy-agent": "^8.0.0",
    "ini": "^6.0.0",
    "ip-address": "^10.1.0",
    "ltx": "^3.1.2",
    "q": "^2.0.3",
    "tar": "^7.5.13",
    "typed-rest-client": "^2.3.0"
  }
}
