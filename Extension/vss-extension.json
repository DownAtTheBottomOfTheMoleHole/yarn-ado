{
    "manifestVersion": 1,
    "id": "yarn-ado",
    "name": "Yarn ADO",
    "version": "0.0.0",
    "publisher": "DownAtTheBottomOfTheMoleHole",    
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],    
    "description": "Community-maintained Yarn tasks for Azure DevOps Pipelines",
    "categories": [
        "Azure Pipelines"
    ],
    "icons": {
        "default": "extension-icon.png"        
    },
    "tags": [
        "yarn",
        "node",
        "npm",
        "package",
        "utility",
        "azure-devops",
        "azure-pipelines"
    ],
    "content": {
        "details": {
            "path": "overview.md"
        },
        "license": {
            "path": "LICENSE.txt"
        }
    },
    "links": {
        "getstarted": {
            "uri": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado#quick-start"
        },
        "support": {
            "uri": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado/issues"
        },
        "repository": {
            "uri": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado"
        },
        "issues": {
            "uri": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado/issues"
        },
        "license": {
            "uri": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado/blob/main/LICENSE.md"
        }
    },
    "branding": {
        "color": "rgb(32, 68, 134)",
        "theme": "dark"
    },  
    "files": [
        {
            "path": "Tasks"
        },
        {
            "path": "Screenshots",
            "addressable": true
        }
    ],
    "repository" :{
        "type": "git",
        "uri": "https://github.com/DownAtTheBottomOfTheMoleHole/yarn-ado"
    }
}